{
  "name": "job-tracker-root",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
  "dev:frontend": "npm run dev -w @job-tracker/frontend",
  "dev:backend": "npm run dev -w @job-tracker/backend",
  "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
  "db:generate": "npm run db:generate -w @job-tracker/frontend"
},
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}